# brainsentry-devops — local config for the deploy scripts and the
# docker-compose.swarm.yml interpolation. Copy to .env and edit.

# ---- Stack identity ----
STACK_NAME=brainsentry

# ---- Image tags from ghcr.io/integrall-tech ----
# Use a specific git tag/SHA in production. `latest` is fine for dev.
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# ---- Host ports (exposed by the swarm) ----
BRAINSENTRY_BACKEND_PORT=8081
BRAINSENTRY_FRONTEND_PORT=8086
BRAINSENTRY_POSTGRES_PORT=5445

# ---- Backend runtime knobs ----
# Match config.yaml or override here; env wins over file.
BRAINSENTRY_AI_MODEL=anthropic/claude-haiku-4-5
BRAINSENTRY_CORS_ORIGINS=http://localhost:3000,https://*.integrall.tech

# ---- GHCR credentials (only if packages are PRIVATE) ----
# Leave empty if the brainsentry-* packages on the org are public.
GHCR_USERNAME=
GHCR_TOKEN=

# ---- Tooling ----
TZ=America/Sao_Paulo
